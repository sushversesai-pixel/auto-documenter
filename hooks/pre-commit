#!/bin/bash
# Auto-generated pre-commit hook for Code Auto-Documenter
# 
# This hook automatically generates documentation for staged Python and JavaScript files
# before each commit, ensuring that documentation stays in sync with code changes.

set -e

echo "🚀 Running Code Auto-Documenter pre-commit hook..."

# Configuration
DOCS_DIR="docs"
MAIN_SCRIPT="main.py"
TEMP_DIR="/tmp/code-autodoc-$$"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Function to cleanup on exit
cleanup() {
    if [ -d "$TEMP_DIR" ]; then
        rm -rf "$TEMP_DIR"
    fi
}
trap cleanup EXIT

# Check if this is a merge commit (skip documentation generation)
if git rev-parse -q --verify MERGE_HEAD > /dev/null; then
    print_warning "Merge commit detected, skipping documentation generation"
    exit 0
fi

# Get list of staged files
print_status "Checking staged files..."

# Get staged Python files
staged_python_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)
python_count=$(echo "$staged_python_files" | grep -v '^$' | wc -l)

# Get staged JavaScript/TypeScript files  
staged_js_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|jsx|tsx)$' || true)
js_count=$(echo "$staged_js_files" | grep -v '^$' | wc -l)

total_staged=$(($python_count + $js_count))

if [ $total_staged -eq 0 ]; then
    print_status "No Python or JavaScript files staged, skipping documentation generation"
    exit 0
fi

print_status "Found $python_count Python files and $js_count JavaScript/TypeScript files to document"

# Check if the main script exists
if [ ! -f "$MAIN_SCRIPT" ]; then
    print_warning "Code Auto-Documenter main script ($MAIN_SCRIPT) not found"
    print_warning "Skipping documentation generation"
    exit 0
fi

# Check if Python is available
if ! command -v python3 &> /dev/null; then
    print_warning "Python 3 not found, skipping documentation generation"
    exit 0
fi

# Check for OpenAI API key
if [ -z "$OPENAI_API_KEY" ]; then
    print_warning "OPENAI_API_KEY environment variable not set"
    print_warning "Documentation generation may fail without API access"
fi

# Create temporary directory for processing
mkdir -p "$TEMP_DIR"

# Create a temporary list of files to process
echo "$staged_python_files" > "$TEMP_DIR/python_files.txt"
echo "$staged_js_files" > "$TEMP_DIR/js_files.txt"

# Generate documentation
print_status "Generating documentation..."

# Determine which languages to process
languages=""
if [ $python_count -gt 0 ]; then
    languages="$languages python"
fi
if [ $js_count -gt 0 ]; then
    languages="$languages javascript"
fi

# Run the documentation generator
if python3 "$MAIN_SCRIPT" generate . \
    --output "$DOCS_DIR" \
    --languages $languages \
    --verbose \
    2>&1 | tee "$TEMP_DIR/doc_generation.log"; then
    
    print_success "Documentation generated successfully"
    
    # Check if any documentation files were created/modified
    if [ -d "$DOCS_DIR" ]; then
        # Stage the generated documentation files
        print_status "Staging documentation files..."
        
        # Add all files in the docs directory
        if git add "$DOCS_DIR/" 2>/dev/null; then
            doc_files_added=$(git diff --cached --name-only | grep "^$DOCS_DIR/" | wc -l)
            
            if [ $doc_files_added -gt 0 ]; then
                print_success "Added $doc_files_added documentation files to commit"
            else
                print_status "No new documentation files to stage"
            fi
        else
            print_warning "Could not stage documentation files"
        fi
    else
        print_warning "Documentation directory not created"
    fi
    
    # Show summary
    print_success "Documentation generation complete!"
    print_status "Processed files:"
    if [ $python_count -gt 0 ]; then
        echo "  Python files: $python_count"
    fi
    if [ $js_count -gt 0 ]; then
        echo "  JavaScript/TypeScript files: $js_count"
    fi
    
else
    print_error "Documentation generation failed"
    
    # Show error details
    if [ -f "$TEMP_DIR/doc_generation.log" ]; then
        print_error "Error details:"
        tail -20 "$TEMP_DIR/doc_generation.log" | sed 's/^/  /'
    fi
    
    print_warning "Proceeding with commit without documentation updates"
    print_warning "You may want to run documentation generation manually:"
    echo "  python3 $MAIN_SCRIPT generate . --output $DOCS_DIR"
fi

# Validate that we're not committing any temporary or cache files
print_status "Validating commit contents..."

# Check for common temporary file patterns
temp_patterns="*.tmp *.temp *.cache *.pyc __pycache__"
for pattern in $temp_patterns; do
    if git diff --cached --name-only | grep -q "$pattern"; then
        print_error "Attempting to commit temporary files matching pattern: $pattern"
        print_error "Please remove these files and try again"
        exit 1
    fi
done

# Final success message
print_success "Pre-commit hook completed successfully"
print_status "Ready to commit with documentation updates"

exit 0
